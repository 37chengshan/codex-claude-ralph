{
  "type": "object",
  "additionalProperties": true,
  "required": [
    "project_name",
    "branch_name",
    "goal",
    "allowed_scope",
    "forbidden_scope",
    "codebase_evidence",
    "acceptance_criteria",
    "verification",
    "risks",
    "discussion_ready",
    "discussion_summary",
    "open_questions",
    "missing_decisions",
    "discussion",
    "user_confirmation",
    "plan_score"
  ],
  "properties": {
    "project_name": { "type": "string" },
    "branch_name": { "type": "string" },
    "goal": { "type": "string" },
    "allowed_scope": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "forbidden_scope": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "codebase_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["claim", "file", "lines"],
        "properties": {
          "claim": { "type": "string" },
          "file": { "type": "string" },
          "lines": { "type": "string" }
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "verification": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["risk", "mitigation"],
        "properties": {
          "risk": { "type": "string" },
          "mitigation": { "type": "string" }
        }
      }
    },
    "discussion_ready": { "type": "boolean" },
    "discussion_summary": { "type": "string" },
    "conversation_language": { "type": "string" },
    "last_explicit_language": { "type": "string" },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "missing_decisions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "discussion": {
      "type": "object",
      "required": ["mode", "round", "status", "task_archetype", "history", "resolved_decisions"],
      "properties": {
        "mode": { "type": "string" },
        "round": { "type": "integer" },
        "status": { "type": "string" },
        "task_archetype": { "type": "string" },
        "current_question": {},
        "history": { "type": "array" },
        "resolved_decisions": { "type": "object" },
        "pressure_pass_completed": { "type": "boolean" },
        "last_explicit_language": { "type": "string" }
      }
    },
    "user_confirmation": { "type": "boolean" },
    "plan_score": { "type": "object" },
    "stories": {
      "type": "array",
      "items": { "type": "object" }
    }
  }
}
